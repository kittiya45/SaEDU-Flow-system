{
  "name": "saedu-flow-system",
  "version": "1.0.0",
  "private": true,
  "description": "Tailwind CSS build tooling for the SAEDU Flow static site — no app code is installed/bundled via npm.",
  "scripts": {
    "build": "postcss tailwind.css -o styles.tailwind.css",
    "watch": "postcss tailwind.css -o styles.tailwind.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.3.1"
  }
}
